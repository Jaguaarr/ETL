# Copier en .env et remplir. Ne JAMAIS committer le fichier .env reel.

# --- PostgreSQL / PostGIS / pgvector ---
PGHOST=localhost
# Port hote du conteneur Docker (docker-compose.yml). Si la connexion
# echoue avec une erreur d'authentification alors que le mot de passe est
# correct, verifier qu'aucun PostgreSQL natif (service Windows/Linux
# installe hors Docker) n'occupe deja ce port sur la machine -- dans ce
# cas, choisir un port different ici ET dans docker-compose.yml (ex:
# 55432), recreer le conteneur (`docker compose up -d --build`).
PGPORT=5433
PGDATABASE=etl_maroc
PGUSER=postgres
PGPASSWORD=changeme_local_dev

# --- Google Maps ---
# Aucune cle API requise : le scraper reellement utilise
# (scripts/gglmaps/scraping/scrape_places.py) automatise un navigateur
# Playwright sur maps.google.com, pas l'API Places -- cf.
# scripts/gglmaps/README.md pour le detail et l'avertissement CGU associe.

# --- User-Agent commun a tous les scrapers HTTP (bonnes pratiques scraping) ---
SCRAPER_CONTACT_EMAIL=votre-email@exemple.com
