# Copier en .env et remplir. Ne JAMAIS committer le fichier .env reel.

# --- PostgreSQL / PostGIS / pgvector ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=etl_maroc
PGUSER=postgres
PGPASSWORD=alhamdolilah

# --- Google Maps Platform (Places API New + Geocoding API) ---
# Creation : console.cloud.google.com -> nouveau projet -> activer
# "Places API (New)" -> Identifiants -> creer une cle API.
# Necessite un compte de facturation actif cote Google (carte enregistree),
# meme si l'usage reste dans le quota gratuit (200$/mois) pour ce volume :
# il n'existe pas d'alternative officielle sans facturation.
GOOGLE_MAPS_API_KEY=

# --- User-Agent commun a tous les scrapers HTTP (bonnes pratiques scraping) ---
SCRAPER_CONTACT_EMAIL=haytamrhallab@gmail.com
